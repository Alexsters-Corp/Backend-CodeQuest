NODE_ENV=development

# Gateway
PORT=4000
FRONTEND_URL=http://localhost:5000
AUTH_SERVICE_URL=http://localhost:4001
LEARNING_SERVICE_URL=http://localhost:4002

# Shared DB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=codequest
DB_NAME=codequest
DB_CONNECTION_LIMIT=10

# Shared JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SMTP (auth-service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@codequest.local

# Feature flags (learning-service)
FEATURE_LEARNING_PATHS=true
FEATURE_LEARNING_LESSONS=true
FEATURE_LEARNING_PROGRESS=true
FEATURE_LEARNING_FAVORITES=true
